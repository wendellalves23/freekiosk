# Cloudflare R2 — OTA APK publish (scripts/push-apk-r2.mjs)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public custom domain bound to the bucket (no trailing slash)
R2_PUBLIC_URL=https://downloads.filare.a23.net.br

# Optional: object key prefix inside the bucket
# FREEKIOSK_R2_RELEASE_PREFIX=releases/freekiosk

# Optional: override manifest URLs compiled into the APK (android/gradle.properties)
# FREEKIOSK_UPDATE_MANIFEST_URL=https://downloads.filare.a23.net.br/releases/freekiosk/latest.json
# FREEKIOSK_UPDATE_MANIFEST_URL_BETA=https://downloads.filare.a23.net.br/releases/freekiosk/latest-beta.json
